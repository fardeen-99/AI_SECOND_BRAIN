{
  "manifest_version": 3,
  "name": "Second Brain",
  "description": "Save the current page, paste any link, or upload files to your Second Brain.",
  "version": "1.0.0",
  "permissions": ["activeTab", "cookies", "scripting", "storage"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Second Brain"
  }
}
