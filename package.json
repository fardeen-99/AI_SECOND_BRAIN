{
  "name": "second-brain-app-root",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "install:backend": "npm ci --prefix second-brain-backend",
    "install:frontend": "npm ci --include=dev --prefix second-brain-frontend",
    "build:frontend": "npm run build --prefix second-brain-frontend",
    "build": "npm run install:backend && npm run install:frontend && npm run build:frontend",
    "start": "cd second-brain-backend && node server.js"
  }
}
